# ==============================================================================
# DIA — Dam Intelligence Agent — Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in the secrets before running.
#   cp .env.example .env

# --- App ---
APP_NAME=dia
APP_ENV=development           # development | production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-openssl-rand-hex-32
APP_BASE_URL=https://dia.linkwise.digital

# --- Error tracking (opcional) ---
# Setar SENTRY_DSN ativa captura de exceções não tratadas. Sem isso é no-op
# silencioso. Em produção altamente recomendado pra capturar falhas em
# dispatchers best-effort (climate fetch, news, notifications).
# sentry-sdk[fastapi] já vem como dep core do projeto desde commit 2026-04-26.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0  # 0.0=off, 0.1=10% das requests viram transactions

# --- Auth (HTTP Basic Auth) ---
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me-strong-password

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://dia:dia_pass@postgres:5432/dia_db
POSTGRES_DB=dia_db
POSTGRES_USER=dia
POSTGRES_PASSWORD=dia_pass

# --- Cache / Broker (Redis) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_REPORTS=claude-opus-4-7
CLAUDE_MODEL_CLASSIFY=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS_REPORT=8192
CLAUDE_MAX_TOKENS_CLASSIFY=512

# --- External climate APIs ---
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
# CEMADEN: NÃO INTEGRADO nesta release. Probe em 2026-04-25 mostrou que os
# endpoints da spec original retornam 404, RSS de alertas vazio, mapa
# interativo sem API JSON. Decisão e re-roteiro em docs/research/cemaden-2026-04.md.
# Mantido aqui só pra não quebrar configs antigas — o app não lê este valor.
CEMADEN_BASE_URL=http://www2.cemaden.gov.br

# --- ANA Hidrowebservice ---
# Fonte oficial brasileira de chuva convencional (ground-truth com validação
# por operadora). Substitui o INMET que saiu do ar em 2026. Requer credencial
# (cadastro em https://www.snirh.gov.br/hidroweb/). O cliente chama /OAUth/v1
# com esses headers e cacheia o Bearer JWT (TTL ~1h) no Redis.
#
# Gotcha: dados têm lag de 2-6 meses (coleta pluviométrica manual). Para
# alertas em tempo real o sinal continua sendo Open-Meteo — ANA entra como
# validação histórica em relatórios e eventos com event_date ± 2d dos que o
# Open-Meteo já detectou (dedup no aggregator mescla os raw_data por fonte).
ANA_BASE_URL=https://www.ana.gov.br/hidrowebservice
ANA_ENABLED=false
ANA_USER=
ANA_PASS=
ANA_LOOKBACK_MONTHS=6
# Fallback: se a estação pluviométrica mais próxima não tiver série
# convencional publicada pra janela pedida, tenta as N-1 seguintes em
# ordem de distância. Sondagem em Ouro Preto mostrou rank 1-6 vazias
# e primeiro hit no rank 7 a 17 km; default 15 cobre até ~20 km.
# Estações vazias vão pra cache negativo Redis (TTL 7d) pra evitar
# re-sondagem a cada ciclo.
ANA_MAX_STATION_CANDIDATES=15

# --- Notifications ---
NOTIFICATIONS_ENABLED=false
N8N_WEBHOOK_URL=https://n8n.linkwise.digital/webhook/dam-alerts
N8N_WEBHOOK_TOKEN=change-me

# --- n8n flow → WAHA (estas vars vivem no CONTAINER do n8n, não no DIA) ---
# O flow docs/n8n-flows/dam-alerts.json envia mensagens via WAHA
# (https://github.com/devlikeapro/waha) self-hosted. n8n autentica em WAHA
# com X-Api-Key. DIA_WEBHOOK_TOKEN acima protege a entrada do webhook;
# as DIA_WAHA_* abaixo protegem a saída pra WAHA. Documentadas aqui pro
# operador setar na UI do n8n quando importar o flow.
#   DIA_WAHA_BASE_URL=https://waha.linkwise.digital
#   DIA_WAHA_API_KEY=change-me
#   DIA_WAHA_SESSION=default
#   DIA_WHATSAPP_TO=5531999999999@c.us   # formato WAHA, NÃO só o número

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=dia@fractaleng.com.br
ALERT_EMAIL_TO=
# Janela mínima entre notificações para a mesma (dam, alert_type) — spec
# §15. Em horas. Aumentar pra 12h em estação chuvosa se gerar spam.
NOTIFICATION_RATE_LIMIT_HOURS=6
# Severidade mínima por canal. WhatsApp em ≥3 (Alto+); email só em ≥4
# (Muito Alto+) pra preservar caixa de entrada de gestor.
NOTIFICATION_MIN_SEVERITY_WHATSAPP=3
NOTIFICATION_MIN_SEVERITY_EMAIL=4

# --- News scraping (feature flags per source) ---
# Google Notícias RSS é a fonte primária: agrega G1 / EM / Folha / UOL /
# Agência Brasil automaticamente via busca textual, é estável e não depende
# de seletores CSS que quebram a cada redesign dos veículos.
NEWS_SOURCE_GOOGLE_NEWS_ENABLED=true
# As demais fontes estão desativadas por padrão em 2026-04:
#   - G1 / EM: seletores da página de busca mudaram, raw_cards=0 em todos os
#     testes. Roteadas via google_news agora.
#   - Agência Brasil: RSS retorna HTTP 500 em todos os endpoints testados.
#   - MPMG: /rss.xml retorna 404 (endpoint histórico descontinuado).
#   - ANM: sem busca pública estável.
# Ative manualmente depois de validar / atualizar a url_template em
# app/services/news/sources.py.
NEWS_SOURCE_G1_ENABLED=false
NEWS_SOURCE_EM_ENABLED=false
NEWS_SOURCE_AGENCIA_BRASIL_ENABLED=false
NEWS_SOURCE_MPMG_ENABLED=false
NEWS_SOURCE_ANM_ENABLED=false

# --- Alert thresholds (mm of rain in 24h) ---
ALERT_RAIN_MM_24H_MODERATE=50
ALERT_RAIN_MM_24H_HIGH=100
ALERT_RAIN_MM_24H_VERY_HIGH=150
ALERT_RAIN_MM_24H_CRITICAL=250
ALERT_FORECAST_DAYS=7

# --- Celery Beat schedules (cron format) ---
SCHEDULE_CLIMATE_FETCH=0 */3 * * *
SCHEDULE_NEWS_SCRAPE=0 6,12,18 * * *
SCHEDULE_ANALYSIS=30 */6 * * *
SCHEDULE_ALERT_CHECK=0 * * * *
SCHEDULE_ALERT_EXPIRATION=15 * * * *
# Sweep de notificações pendentes a cada 5min — curto pra alerta crítico
# chegar rápido; o rate-limit (6h por dam+type) protege contra spam.
SCHEDULE_NOTIFICATIONS=*/5 * * * *
SCHEDULE_REPORT_BRIEFING=0 7 * * 1
SCHEDULE_REPORT_CLIENT=0 8 1 * *

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json               # json | console
