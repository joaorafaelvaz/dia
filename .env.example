# ==============================================================================
# DIA — Dam Intelligence Agent — Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in the secrets before running.
#   cp .env.example .env

# --- App ---
APP_NAME=dia
APP_ENV=development           # development | production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-openssl-rand-hex-32
APP_BASE_URL=https://dia.linkwise.digital

# --- Auth (HTTP Basic Auth) ---
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me-strong-password

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://dia:dia_pass@postgres:5432/dia_db
POSTGRES_DB=dia_db
POSTGRES_USER=dia
POSTGRES_PASSWORD=dia_pass

# --- Cache / Broker (Redis) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_REPORTS=claude-opus-4-7
CLAUDE_MODEL_CLASSIFY=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS_REPORT=8192
CLAUDE_MAX_TOKENS_CLASSIFY=512

# --- External climate APIs ---
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
INMET_BASE_URL=https://apitempo.inmet.gov.br
CEMADEN_BASE_URL=http://www.cemaden.gov.br

# --- Notifications ---
NOTIFICATIONS_ENABLED=false
N8N_WEBHOOK_URL=https://n8n.linkwise.digital/webhook/dam-alerts
N8N_WEBHOOK_TOKEN=change-me
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=dia@fractaleng.com.br
ALERT_EMAIL_TO=

# --- News scraping (feature flags per source) ---
NEWS_SOURCE_G1_ENABLED=true
NEWS_SOURCE_EM_ENABLED=true
NEWS_SOURCE_AGENCIA_BRASIL_ENABLED=true
# MPMG e ANM desabilitados por padrão: MPMG RSS responde 404 (endpoint histórico
# /rss.xml não existe mais); ANM não expõe busca pública estável. Ative manualmente
# depois de atualizar a url_template em app/services/news/sources.py.
NEWS_SOURCE_MPMG_ENABLED=false
NEWS_SOURCE_ANM_ENABLED=false

# --- Alert thresholds (mm of rain in 24h) ---
ALERT_RAIN_MM_24H_MODERATE=50
ALERT_RAIN_MM_24H_HIGH=100
ALERT_RAIN_MM_24H_VERY_HIGH=150
ALERT_RAIN_MM_24H_CRITICAL=250
ALERT_FORECAST_DAYS=7

# --- Celery Beat schedules (cron format) ---
SCHEDULE_CLIMATE_FETCH=0 */3 * * *
SCHEDULE_NEWS_SCRAPE=0 6,12,18 * * *
SCHEDULE_ANALYSIS=30 */6 * * *
SCHEDULE_ALERT_CHECK=0 * * * *
SCHEDULE_ALERT_EXPIRATION=15 * * * *
SCHEDULE_REPORT_BRIEFING=0 7 * * 1
SCHEDULE_REPORT_CLIENT=0 8 1 * *

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json               # json | console
